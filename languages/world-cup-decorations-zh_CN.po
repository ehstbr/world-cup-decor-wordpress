msgid "Settings"
msgstr "设置"

msgid "World Cup decorations preview"
msgstr "世界杯装饰预览"

msgid "This modal simulates the current settings on a fake store page. Unsaved changes are included in the preview."
msgstr "This modal simulates the current settings on a fake store page. Unsaved changes are included in the preview."

msgid "Close preview"
msgstr "关闭预览"

msgid "Demo battery store"
msgstr "演示电池商店"

msgid "Search for products..."
msgstr "搜索产品..."

msgid "Categories"
msgstr "分类"

msgid "Home"
msgstr "首页"

msgid "Offers"
msgstr "优惠"

msgid "Blog"
msgstr "博客"

msgid "Cart"
msgstr "购物车"

msgid "World Cup offer"
msgstr "世界杯优惠"

msgid "Decorated storefront preview"
msgstr "装饰店铺预览"

msgid "Bunting, confetti and intro-only elements are rendered over this simulated page."
msgstr "Bunting, confetti and intro-only elements are rendered over this simulated page."

msgid "Buy now"
msgstr "立即购买"

msgid "Car batteries"
msgstr "汽车电池"

msgid "Motorcycle batteries"
msgstr "摩托车电池"

msgid "Chargers and tools"
msgstr "充电器和工具"

msgid "Intro only"
msgstr "仅开场"

msgid "Bunting is disabled in the current settings."
msgstr "Bunting is disabled in the current settings."

msgid "Preview only: this does not set cookies and does not change the public site until you save."
msgstr "Preview only: this does not set cookies and does not change the public site until you save."

msgid "Subtle decoration for WordPress and WooCommerce sites: SVG bunting, falling confetti, intro-only animations with a bouncing ball, a realistic vuvuzela and a tactical clipboard, all with country-based colors and repeat controls."
msgstr "Subtle decoration for WordPress and WooCommerce sites: SVG bunting, falling confetti, intro-only animations with a bouncing ball, a realistic vuvuzela and a tactical clipboard, all with country-based colors and repeat controls."

msgid "Main settings"
msgstr "主要设置"

msgid "Choose the country palette, decorative elements, intro behavior and mobile handling."
msgstr "Choose the country palette, decorative elements, intro behavior and mobile handling."

msgid "Enable decorations on the site"
msgstr "在网站启用装饰"

msgid "Country / Theme colors"
msgstr "国家 / 主题颜色"

msgid "SVG colors adapt to the selected country palette."
msgstr "SVG colors adapt to the selected country palette."

msgid "Decorative elements"
msgstr "装饰元素"

msgid "Bunting"
msgstr "彩旗"

msgid "Paper confetti"
msgstr "纸屑"

msgid "Bouncing ball — intro only"
msgstr "弹跳足球 — 仅开场"

msgid "Vuvuzela — intro only"
msgstr "呜呜祖拉 — 仅开场"

msgid "Tactics board — intro only"
msgstr "战术板 — 仅开场"

msgid "Bunting density"
msgstr "彩旗密度"

msgid "Coverage means how much of the screen width is visually occupied by pennants. The plugin calculates the number of flags automatically based on the viewport width."
msgstr "Coverage means how much of the screen width is visually occupied by pennants. The plugin calculates the number of flags automatically based on the viewport width."

msgid "Desktop horizontal coverage"
msgstr "桌面水平覆盖率"

msgid "Mobile horizontal coverage"
msgstr "移动端水平覆盖率"

msgid "Intro animation behavior"
msgstr "开场动画行为"

msgid "The ball, vuvuzela and tactics board appear only during the intro animation. After that, only subtle decorations remain on the page."
msgstr "The ball, vuvuzela and tactics board appear only during the intro animation. After that, only subtle decorations remain on the page."

msgid "Repeat full intro animation"
msgstr "重复完整开场动画"

msgid "Only once per browser session"
msgstr "每个浏览器会话一次"

msgid "Every X days using a cookie"
msgstr "每 X 天使用 Cookie"

msgid "Always repeat — useful only for testing"
msgstr "始终重复 — 仅用于测试"

msgid "Cookie days"
msgstr "Cookie 天数"

msgid "Controls when the full intro animation can be displayed again."
msgstr "Controls when the full intro animation can be displayed again."

msgid "Initial paper pieces"
msgstr "初始纸屑数量"

msgid "Total number of paper pieces released during the intro animation."
msgstr "Total number of paper pieces released during the intro animation."

msgid "Continuous paper pieces per second"
msgstr "持续纸屑/秒"

msgid "Average number of paper pieces generated per second after the intro. Example: 0.20 means one piece every five seconds."
msgstr "Average number of paper pieces generated per second after the intro. Example: 0.20 means one piece every five seconds."

msgid "Mobile & compatibility"
msgstr "移动端和兼容性"

msgid "Disable all decorations on mobile devices"
msgstr "在移动设备上禁用所有装饰"

msgid "Mobile breakpoint (px)"
msgstr "移动端断点 (px)"

msgid "If disabled on mobile is enabled, widths equal to or below this value will not render decorations."
msgstr "If disabled on mobile is enabled, widths equal to or below this value will not render decorations."

msgid "Do not show on WooCommerce cart, checkout and My Account pages"
msgstr "Do not show on WooCommerce cart, checkout and My Account pages"

msgid "Respect users with reduced motion enabled in their system"
msgstr "Respect users with reduced motion enabled in their system"

msgid "Visual layer / z-index"
msgstr "Visual layer / z-index"

msgid "Increase only if a theme element is covering the decoration."
msgstr "Increase only if a theme element is covering the decoration."

msgid "Save settings"
msgstr "保存设置"

msgid "Preview"
msgstr "预览"

msgid "Open a simulated storefront using the current settings. It is better than the old static preview and also works with unsaved form changes."
msgstr "Open a simulated storefront using the current settings. It is better than the old static preview and also works with unsaved form changes."

msgid "Open preview modal"
msgstr "打开预览窗口"

msgid "The preview runs inside this settings screen only. It does not affect cookies, visitors or your public frontend."
msgstr "The preview runs inside this settings screen only. It does not affect cookies, visitors or your public frontend."
